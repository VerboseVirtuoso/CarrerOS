# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# Hardcoded user ID used while auth is disabled (dev only)
# Change this string to simulate a different user account
DEV_USER_ID=dev-user-001

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/job-tracker?retryWrites=true&w=majority

# JSON Web Token secret (generate a long random string, e.g. openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_here

# JWT expiry (e.g. 7d, 24h)
JWT_EXPIRES_IN=7d

# ─── Nodemailer / Email ───────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="CarrerOS <your_email@gmail.com>"

# ─── Client ───────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000/api
